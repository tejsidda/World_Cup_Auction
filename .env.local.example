# Supabase — use the **anon public** key (NOT service_role) in the browser.
# For local dev, copy to .env.local (Next.js loads it automatically).
# On Vercel: Project Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL (Phase 6 hardening) — server-only service role key for true blind bidding.
# Found in Supabase Dashboard → Project Settings → API → service_role (keep SECRET,
# never expose to the browser; no NEXT_PUBLIC_ prefix). When set, the server reads/writes
# bids with this key so the public anon key can't peek at live bids. After setting it,
# run supabase/migrations/014_harden_bids_optional.sql.
SUPABASE_SERVICE_ROLE_KEY=

# Auth setup (Phase 1 — after running supabase/migrations/010_profiles_auth.sql):
# 1. Supabase Dashboard → Authentication → Providers → enable Email
#    (Allow password sign-in; for instant signup turn OFF "Confirm email")
# 2. Authentication → URL Configuration → Redirect URLs (magic link only):
#    - http://localhost:3000/auth/callback
#    - https://YOUR-PRODUCTION-DOMAIN/auth/callback
# 3. SQL Editor → make yourself admin:
#    insert into auction_admin_emails (email) values ('you@example.com');
